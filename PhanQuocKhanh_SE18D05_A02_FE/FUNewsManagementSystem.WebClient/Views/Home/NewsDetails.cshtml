@model FUNewsManagementSystem.WebClient.Models.NewsDetailsViewModel
@using System.Text.Json
@{
    var article = Model.Article;
    ViewData["Title"] = article.SeoMeta.Title;
    ViewData["MetaDescription"] = article.SeoMeta.Description;
    ViewData["CanonicalUrl"] = Model.CanonicalUrl;
    ViewData["Robots"] = "index,follow";

    var jsonLd = JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "NewsArticle",
        ["headline"] = article.DisplayTitle,
        ["description"] = article.SeoMeta.Description,
        ["datePublished"] = article.CreatedDate?.ToString("O"),
        ["dateModified"] = (article.ModifiedDate ?? article.CreatedDate)?.ToString("O"),
        ["mainEntityOfPage"] = new Dictionary<string, object?> { ["@type"] = "WebPage", ["@id"] = Model.CanonicalUrl },
        ["author"] = new Dictionary<string, object?> { ["@type"] = "Person", ["name"] = article.DisplayAuthor ?? "FU News Staff" },
        ["publisher"] = new Dictionary<string, object?> { ["@type"] = "Organization", ["name"] = "FU News Management System" }
    });
}

@section Head {
    <meta property="og:type" content="article" />
    <meta property="og:title" content="@article.SeoMeta.Title" />
    <meta property="og:description" content="@article.SeoMeta.Description" />
    <meta property="og:url" content="@Model.CanonicalUrl" />
    <meta property="article:published_time" content="@article.CreatedDate?.ToString("O")" />
    <meta property="article:modified_time" content="@(article.ModifiedDate ?? article.CreatedDate)?.ToString("O")" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="@article.SeoMeta.Title" />
    <meta name="twitter:description" content="@article.SeoMeta.Description" />
    <script type="application/ld+json">@Html.Raw(jsonLd)</script>
}

<div class="app-content article-page">
    <a href="/" class="btn btn-ghost btn-sm article-back-link"><span aria-hidden="true">&larr;</span> Back to News</a>

    <article class="article-shell">
        <span class="section-label">@article.DisplayCategory</span>
        <h1 id="articleTitle">@article.DisplayTitle</h1>
        <div class="article-byline">
            @if (!string.IsNullOrWhiteSpace(article.DisplayAuthor))
            {
                <span>By @article.DisplayAuthor</span>
            }
            @if (article.CreatedDate is not null)
            {
                <time datetime="@article.CreatedDate.Value.ToString("O")">@article.CreatedDate.Value.ToString("dd MMMM yyyy")</time>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(article.Headline) && article.Headline != article.DisplayTitle)
        {
            <p class="article-headline">@article.Headline</p>
        }
        <hr />
        <div id="articleContent" class="article-content ql-editor">@Html.Raw(Model.NewsContentHtml)</div>

        @if (article.Tags.Count > 0)
        {
            <div class="article-tags" aria-label="Article tags">
                @foreach (var tag in article.Tags)
                {
                    <span class="badge text-bg-secondary">@tag.TagName</span>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(article.NewsSource))
        {
            <p class="article-source"><strong>Source:</strong> @article.NewsSource</p>
        }
    </article>
</div>
