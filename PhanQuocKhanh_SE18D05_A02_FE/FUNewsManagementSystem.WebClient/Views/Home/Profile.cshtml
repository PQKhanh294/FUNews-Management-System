@{
    ViewData["Title"] = "Profile";
}

<div class="page-header">
    <div class="page-header-inner">
        <div>
            <span class="page-eyebrow">Account</span>
            <h1 class="page-title">My Profile</h1>
            <p class="page-subtitle">Update your display name and change your password.</p>
        </div>
    </div>
</div>

<div class="app-content">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="page-section p-4">
                <img id="avatar" class="avatar d-none mb-4" alt="avatar" />
                <form id="profileForm">
                    <div class="mb-3">
                        <label class="form-label">Display name</label>
                        <input class="form-control" id="profileName" placeholder="Your full name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Current password</label>
                        <input class="form-control" id="currentPassword" type="password" placeholder="Required to change password" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">New password</label>
                        <input class="form-control" id="newPassword" type="password" placeholder="Leave blank to keep current" />
                    </div>
                    <button class="btn btn-primary w-100" type="submit">Save changes</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/profile.js" asp-append-version="true"></script>
}
