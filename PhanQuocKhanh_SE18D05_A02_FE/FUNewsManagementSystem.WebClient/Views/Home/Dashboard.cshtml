@{
    ViewData["Title"] = "Report";
}

<div class="page-header">
    <div class="page-header-inner">
        <div>
            <span class="page-eyebrow">Admin</span>
            <h1 class="page-title">Analytics Report</h1>
            <p class="page-subtitle">Article statistics by category, sorted by the selected period.</p>
        </div>
        <div class="page-actions">
            <input class="form-control" id="startDate" type="date" style="width:148px;" />
            <input class="form-control" id="endDate" type="date" style="width:148px;" />
            <button class="btn btn-primary" id="btnLoadReport">Run report</button>
        </div>
    </div>
</div>

<div class="app-content">
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="surface-panel p-4 h-100">
                <p class="fw-700 mb-3" style="font-size:13px; color:var(--text-tertiary); text-transform:uppercase; letter-spacing:.06em;">Distribution</p>
                <canvas id="newsChart"></canvas>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="page-section">
                <div class="page-toolbar">
                    <div>
                        <span class="section-label">By category</span>
                        <p class="page-subtitle mb-0">Articles created in the selected date range.</p>
                    </div>
                </div>
                <table class="table table-hover w-100" id="reportTable">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th>Total</th>
                            <th>Latest</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}
